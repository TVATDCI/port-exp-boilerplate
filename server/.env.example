# Server
MONGO_URI=mongodb+srv://yourusername:PASSWORD_HERE@cluster.mongodb.net/yourdbname?retryWrites=true&w=majority
PORT=5001
NODE_ENV=development

# Client (CORS configuration - only this origin can access API)
CLIENT_URL=http://localhost:5173

# Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme123

# Auth
JWT_SECRET=your-secret-key-here
JWT_EXPIRES_IN=7d
