{
  "testEnvironment": "node",
  "coverageDirectory": "coverage",
  "collectCoverageFrom": ["src/**/*.js", "!src/config/database.js"],
  "coverageThreshold": {
    "global": {
      "branches": 50,
      "functions": 50,
      "lines": 50,
      "statements": 50
    }
  },
  "testMatch": ["**/__tests__/**/*.js", "**/*.test.js", "**/*.spec.js"],
  "verbose": true,
  "testTimeout": 10000
}
